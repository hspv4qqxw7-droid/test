/* ─── GAMES ─── */
.games-section { background: var(--card); }
.games-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 0.8rem; margin-top: 3rem;
}
.game-tag {
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 8px; padding: 0.8rem 1rem;
  font-size: 0.82rem; font-weight: 500;
  text-align: center; color: rgba(232,234,240,0.7);
  transition: border-color 0.2s, color 0.2s;
}
.game-tag:hover { border-color: rgba(0,212,255,0.3); color: var(--cyan); }
.game-tag .gi { font-size: 1.2rem; display: block; margin-bottom: 0.3rem; }

.games-note {
  margin-top: 1.5rem; font-size: 0.85rem;
  color: var(--muted); line-height: 1.7;
}
.games-note a { color: var(--cyan); text-decoration: none; }

/* ─── MEMBERSHIP ─── */
.membership-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 3rem; align-items: center; margin-top: 3.5rem;
}
.membership-perks { display: flex; flex-direction: column; gap: 1.2rem; }
.perk {
  display: flex; gap: 1rem; align-items: flex-start;
  padding: 1.2rem; background: var(--card);
  border: 1px solid var(--border); border-radius: 10px;
  transition: border-color 0.2s;
}
.perk:hover { border-color: rgba(0,212,255,0.2); }
.perk-icon { font-size: 1.5rem; flex-shrink: 0; }
.perk-title { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.2rem; }
.perk-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.6; }

.membership-cta {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 2.5rem;
  text-align: center;
}
.membership-cta .sec-title { font-size: 2rem; margin-bottom: 0.8rem; }
.membership-cta p { font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin-bottom: 2rem; }

/* ─── INFO STRIP ─── */
.info-strip {
  background: var(--card);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.info-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  divide-x: 1px solid var(--border);
}
.info-tile {
  padding: 2rem 1.8rem;
  border-right: 1px solid var(--border);
}
.info-tile:last-child { border-right: none; }
.info-tile-label {
  font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 0.6rem;
}
.info-tile-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem; font-weight: 700; color: var(--text);
  line-height: 1.4;
}
.info-tile-val a { color: var(--cyan); text-decoration: none; }
.info-tile-val a:hover { text-decoration: underline; }

/* ─── FOOTER ─── */
footer {
  padding: 3rem 5% 2rem;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 1.5rem;
}
.foot-logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.3rem; font-weight: 900; text-transform: uppercase;
}
.foot-logo .hi { color: var(--cyan); }
.foot-copy { font-size: 0.78rem; color: var(--muted); }
.foot-links { display: flex; gap: 1.5rem; }
.foot-links a {
  font-size: 0.8rem; color: var(--muted); text-decoration: none;
  transition: color 0.2s;
}
.foot-links a:hover { color: var(--cyan); }

/* ─── REVEAL ─── */
.reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s, transform 0.6s; }
.reveal.in { opacity: 1; transform: none; }

/* ─── RESPONSIVE ─── */
@media(max-width: 900px) {
